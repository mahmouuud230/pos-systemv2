<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_barcode_scanner" model="ir.ui.view">
        <field name="name">product.template.form.barcode.scanner</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="barcode" widget="barcode_scanner"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_view_barcode_scanner" model="ir.ui.view">
        <field name="name">product.product.form.barcode.scanner</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="widget">barcode_scanner</attribute>
            </xpath>
        </field>
    </record>
</odoo>
