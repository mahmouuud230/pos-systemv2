<?xml version="1.0" encoding="utf-8"?>
<!-- addons/pos_barcode_product_form/views/product_template_views.xml -->
<odoo>
    <record id="product_template_form_view_barcode_scanner" model="ir.ui.view">
        <field name="name">product.template.form.barcode.scanner</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="replace">
                <field name="barcode" widget="barcode_scanner"/>
            </xpath>
        </field>
    </record>
</odoo>
