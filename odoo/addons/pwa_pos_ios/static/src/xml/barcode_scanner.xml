<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!--
        BarcodeCharField
        ─────────────────
        Replaces the plain text input for the "barcode" field with:
          [ barcode text input ] [ 📷 camera button ]

        When camera button is tapped:
          → BarcodeScannerModal opens fullscreen
          → Camera reads barcode
          → Value inserted into field automatically
          → Modal closes
    -->
    <t t-name="pwa_pos_ios.BarcodeCharField">
        <div class="o_field_barcode_scanner"
             t-att-class="scannerState.justScanned ? 'o_barcode_just_scanned' : ''">

            <!-- Original CharField input (renders the text box normally) -->
            <t t-call="web.CharField"/>

            <!-- Camera button — only shown in edit mode -->
            <button t-if="!props.readonly"
                    class="o_barcode_scan_btn btn btn-secondary"
                    title="Scan barcode with camera"
                    aria-label="Scan barcode with camera"
                    t-on-click.stop="openScanner">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round" aria-hidden="true">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8
                             a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                    <circle cx="12" cy="13" r="4"/>
                </svg>
                <span class="ms-1 d-none d-sm-inline">Scan</span>
            </button>

            <!-- Success flash -->
            <span t-if="scannerState.justScanned"
                  class="o_barcode_scan_success">
                ✓ Scanned
            </span>

            <!-- Scanner modal — rendered inline, shown as overlay via CSS -->
            <BarcodeScannerModal
                t-if="scannerState.open"
                onScan.bind="onScanResult"
                onClose.bind="closeScanner"/>

        </div>
    </t>

</templates>
