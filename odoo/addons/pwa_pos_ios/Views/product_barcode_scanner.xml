<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Override the product form to use our custom barcode_with_scanner
        widget on the barcode field. This adds the camera button.

        Applies to:
          - product.template (main product form)
          - product.product  (product variant form)
    -->

    <!-- Product Template form -->
    <record id="product_template_barcode_scanner" model="ir.ui.view">
        <field name="name">product.template.barcode.scanner</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="replace">
                <field name="barcode"
                       widget="barcode_with_scanner"
                       placeholder="Scan or type barcode..."/>
            </xpath>
        </field>
    </record>

    <!-- Product Variant form -->
    <record id="product_product_barcode_scanner" model="ir.ui.view">
        <field name="name">product.product.barcode.scanner</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="replace">
                <field name="barcode"
                       widget="barcode_with_scanner"
                       placeholder="Scan or type barcode..."/>
            </xpath>
        </field>
    </record>

</odoo>
